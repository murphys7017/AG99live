{
  "name": "ag99live-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./out/main/index.cjs",
  "scripts": {
    "dev": "node scripts/electron-vite-runner.cjs dev",
    "start": "node scripts/electron-vite-runner.cjs preview",
    "dev:web": "vite",
    "typecheck": "npm run typecheck:renderer && npm run typecheck:node",
    "typecheck:renderer": "vue-tsc --noEmit -p tsconfig.json",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "build": "npm run typecheck && electron-vite build",
    "build:web": "vue-tsc --noEmit -p tsconfig.json && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "@types/node": "^22.15.3",
    "electron": "^35.5.1",
    "electron-vite": "^3.1.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vue-tsc": "^2.1.8"
  }
}
